{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Daily Reporter",
  "version": "0.1.0",
  "identifier": "com.qstdc.gitdailyreporter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Git Daily Reporter",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
